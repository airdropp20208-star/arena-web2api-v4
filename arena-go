#!/usr/bin/env bash
# arena-go — 1 lệnh duy nhất: setup + start + mở Kiwi
#
# Cài shortcut trên home screen:
#   Long-press desktop → Widget → Termux:Widget → Termux shortcut
#   Command: arena-go
#
# Hoặc chạy trong Termux:
#   arena-go

set -u

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

log()  { echo -e "${GREEN}✓${NC} $*"; }
info() { echo -e "${CYAN}ℹ${NC} $*"; }
warn() { echo -e "${YELLOW}⚠${NC} $*"; }
err()  { echo -e "${RED}✗${NC} $*" >&2; }

ARENA_DIR="${ARENA_DIR:-$HOME/arena-web2api-v4}"

echo ""
echo "═══════════════════════════════════════════════════════"
echo "  🚀 arena-go — One Click Start"
echo "═══════════════════════════════════════════════════════"
echo ""

# ── Bước 1: Check code tồn tại ─────────────────────────────────────────────
if [ ! -f "$ARENA_DIR/main.py" ]; then
    info "Lần đầu — clone code..."
    git clone https://github.com/airdropp20208-star/arena-web2api-v4.git "$ARENA_DIR" 2>/dev/null || {
        err "Không clone được. Kiểm tra internet."
        exit 1
    }
    cd "$ARENA_DIR"
    bash auto-setup.sh
    log "Setup xong. Edit .env rồi chạy lại arena-go."
    exit 0
fi

cd "$ARENA_DIR"

# ── Bước 2: Check .env ─────────────────────────────────────────────────────
if [ ! -f .env ] || ! grep -q "ARENA_AUTH_COOKIE=." .env; then
    warn ".env chưa có cookie. Chạy: arena setup"
    exit 1
fi

# ── Bước 3: Check deps ─────────────────────────────────────────────────────
if ! python3 -c "import fastapi, httpx" 2>/dev/null; then
    info "Cài deps..."
    pip install -r requirements.txt --quiet --break-system-packages 2>/dev/null || true
fi

# ── Bước 4: Start server (nếu chưa chạy) ───────────────────────────────────
if ! curl -s -m 2 http://127.0.0.1:8000/health 2>/dev/null | grep -q '"ok"'; then
    info "Starting server..."
    chmod +x arena broker-only.sh keepalive.sh 2>/dev/null || true
    termux-wake-lock 2>/dev/null || true

    LOG_DIR="$HOME/.arena/logs"
    mkdir -p "$LOG_DIR" 2>/dev/null || true

    if command -v setsid >/dev/null 2>&1; then
        setsid bash keepalive.sh > "$LOG_DIR/keepalive.log" 2>&1 < /dev/null &
    else
        nohup bash keepalive.sh > "$LOG_DIR/keepalive.log" 2>&1 < /dev/null &
    fi
    disown 2>/dev/null || true

    # Đợi server ready
    for i in $(seq 1 20); do
        if curl -s -m 2 http://127.0.0.1:8000/health 2>/dev/null | grep -q '"ok"'; then
            log "Server ready!"
            break
        fi
        sleep 1
        echo -n "."
    done
    echo ""
else
    log "Server đang chạy."
fi

# ── Bước 5: Mở Kiwi Browser (nếu chưa mở) ──────────────────────────────────
# Termux không thể check app khác đang chạy, cứ mở (sẽ focus nếu đang chạy)
if command -v am >/dev/null 2>&1; then
    info "Mở Kiwi Browser..."
    # Mở arena.ai trực tiếp
    am start -n com.kiwibrowser.browser/com.google.android.apps.chrome.Main \
        -a android.intent.action.VIEW \
        -d "https://arena.ai" 2>/dev/null || \
    am start -a android.intent.action.VIEW -d "https://arena.ai" 2>/dev/null || true
fi

# ── Bước 6: Status ─────────────────────────────────────────────────────────
echo ""
sleep 3
echo "═══════════════════════════════════════════════════════"
echo "  📊 Status"
echo "═══════════════════════════════════════════════════════"

if curl -s -m 3 http://127.0.0.1:8000/health 2>/dev/null | grep -q '"ok"'; then
    echo -e "  Server:     ${GREEN}✓ running${NC} (http://127.0.0.1:8000)"
else
    echo -e "  Server:     ${RED}✗ down${NC}"
fi

if pgrep -f "keepalive.sh" >/dev/null 2>&1; then
    echo -e "  Keepalive:  ${GREEN}✓ running${NC}"
else
    echo -e "  Keepalive:  ${RED}✗ not running${NC}"
fi

# Extension status
broker_json=$(curl -s -m 3 http://127.0.0.1:8000/admin/broker 2>/dev/null)
if [ -n "$broker_json" ]; then
    ext=$(echo "$broker_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('extension_connected', False))" 2>/dev/null)
    tokens=$(echo "$broker_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('token_count', 0))" 2>/dev/null)
    cached=$(echo "$broker_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('cached_token', False))" 2>/dev/null)
    if [ "$ext" = "True" ]; then
        cache_str=""
        [ "$cached" = "True" ] && cache_str=" (cached: ✓)"
        echo -e "  Extension:  ${GREEN}✓ connected${NC} (tokens: $tokens$cache_str)"
    else
        echo -e "  Extension:  ${YELLOW}⏳ waiting${NC} — mở Kiwi → click icon extension"
    fi
fi

echo ""
echo "═══════════════════════════════════════════════════════"
echo "  Server chạy ngầm. Có thể tắt Termux."
echo "  Kiwi Browser đã mở — click icon extension để verify."
echo ""
echo "  Test chat:"
echo "    curl -X POST http://127.0.0.1:8000/v1/chat/completions \\"
echo "      -H \"Content-Type: application/json\" \\"
echo "      -d '{\"model\":\"arena-battle\",\"messages\":[{\"role\":\"user\",\"content\":\"hello\"}]}'"
echo "═══════════════════════════════════════════════════════"
