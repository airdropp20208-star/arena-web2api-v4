#!/usr/bin/env bash
# arena-go — Split-screen: Termux (trên) + Kiwi (dưới)
#
# 1 lệnh: start server + mở split-screen
# Termux nửa trên (log server), Kiwi nửa dưới (arena.ai + chat)

set -u

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
NC='\033[0m'

log()  { echo -e "${GREEN}✓${NC} $*"; }
info() { echo -e "${CYAN}ℹ${NC} $*"; }
warn() { echo -e "${YELLOW}⚠${NC} $*"; }
err()  { echo -e "${RED}✗${NC} $*" >&2; }

ARENA_DIR="${ARENA_DIR:-$HOME/arena-web2api-v4}"

echo ""
echo "═══════════════════════════════════════════════════════"
echo "  🚀 arena-go — Split Screen Mode"
echo "  Termux (trên) + Kiwi Browser (dưới)"
echo "═══════════════════════════════════════════════════════"
echo ""

# ── Check ──────────────────────────────────────────────────────────────────
if [ ! -f "$ARENA_DIR/main.py" ]; then
    err "Code không tồn tại. Chạy: git clone + bash auto-setup.sh"
    exit 1
fi

cd "$ARENA_DIR"

if [ ! -f .env ] || ! grep -q "ARENA_AUTH_COOKIE=." .env; then
    warn ".env chưa có cookie. Chạy: arena setup"
    exit 1
fi

# ── Start server (ngầm nếu chưa chạy) ──────────────────────────────────────
if ! curl -s -m 2 http://127.0.0.1:8000/health 2>/dev/null | grep -q '"ok"'; then
    info "Starting server..."
    chmod +x arena keepalive.sh 2>/dev/null || true
    termux-wake-lock 2>/dev/null || true

    LOG_DIR="$HOME/.arena/logs"
    mkdir -p "$LOG_DIR" 2>/dev/null || true

    if command -v setsid >/dev/null 2>&1; then
        setsid bash keepalive.sh > "$LOG_DIR/keepalive.log" 2>&1 < /dev/null &
    else
        nohup bash keepalive.sh > "$LOG_DIR/keepalive.log" 2>&1 < /dev/null &
    fi
    disown 2>/dev/null || true

    for i in $(seq 1 20); do
        if curl -s -m 2 http://127.0.0.1:8000/health 2>/dev/null | grep -q '"ok"'; then
            log "Server ready!"
            break
        fi
        sleep 1
        echo -n "."
    done
    echo ""
else
    log "Server đang chạy."
fi

# ── Mở Kiwi ở split-screen ─────────────────────────────────────────────────
if command -v am >/dev/null 2>&1; then
    info "Mở Kiwi Browser (split-screen)..."

    # Mở arena.ai — Kiwi sẽ mở ở nửa dưới (split-screen auto)
    am start \
        --windowing-mode multi-window \
        -n com.kiwibrowser.browser/com.google.android.apps.chrome.Main \
        -a android.intent.action.VIEW \
        -d "https://arena.ai" 2>/dev/null || \
    am start -a android.intent.action.VIEW -d "https://arena.ai" 2>/dev/null || true

    sleep 3

    # Mở tab 2: Chat UI
    am start \
        -n com.kiwibrowser.browser/com.google.android.apps.chrome.Main \
        -a android.intent.action.VIEW \
        -d "http://127.0.0.1:8000/web-ui" 2>/dev/null || true
fi

# ── Hiển thị log real-time (Termux ở nửa trên) ─────────────────────────────
echo ""
echo "═══════════════════════════════════════════════════════"
echo "  📊 Status"
echo "═══════════════════════════════════════════════════════"

if curl -s -m 3 http://127.0.0.1:8000/health 2>/dev/null | grep -q '"ok"'; then
    echo -e "  Server:     ${GREEN}✓ running${NC} (http://127.0.0.1:8000)"
else
    echo -e "  Server:     ${RED}✗ down${NC}"
fi

broker_json=$(curl -s -m 3 http://127.0.0.1:8000/admin/broker 2>/dev/null)
if [ -n "$broker_json" ]; then
    ext=$(echo "$broker_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('extension_connected', False))" 2>/dev/null)
    tokens=$(echo "$broker_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('token_count', 0))" 2>/dev/null)
    cached=$(echo "$broker_json" | python3 -c "import json,sys; print(json.load(sys.stdin).get('cached_token', False))" 2>/dev/null)
    if [ "$ext" = "True" ]; then
        cache_str=""
        [ "$cached" = "True" ] && cache_str=" (cached: ✓ REALTIME)"
        echo -e "  Extension:  ${GREEN}✓ connected${NC} (tokens: $tokens$cache_str)"
    else
        echo -e "  Extension:  ${YELLOW}⏳ waiting${NC} — Kiwi đang mở, đợi extension poll..."
    fi
fi

echo ""
echo "═══════════════════════════════════════════════════════"
echo ""
echo "  Kiwi đã mở — arena.ai (Tab 1) + Chat UI (Tab 2)"
echo ""
echo "  💡 TIP: Nếu chưa split-screen, vuốt lên từ đáy →"
echo "     hold Termux → 'Split screen' → chọn Kiwi"
echo ""
echo "  Log server (Ctrl-C để dừng xem log, server vẫn chạy):"
echo "═══════════════════════════════════════════════════════"
echo ""

# Tail log — Termux ở nửa trên hiển thị log
tail -F "$HOME/.arena/logs/keepalive.log" "$HOME/.arena/logs/arena-server.log" 2>/dev/null
