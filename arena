#!/data/data/com.termux/files/usr/bin/bash
# arena — CLI entry point cho arena-web2api
#
# Usage:
#   arena setup   — cài deps + tạo .env (interactive, không cần nano)
#   arena start   — khởi động server + keepalive (background)
#   arena stop    — dừng server + keepalive
#   arena status  — xem trạng thái
#   arena restart — restart server
#   arena logs    — xem log real-time
#   arena test    — chạy test suite
#   arena update  — git pull + restart
#   arena uninstall — remove symlink (giữ code)
#
# Cài đặt:  bash install.sh
# Sau đó dùng:  arena setup / arena start / ...

set -u

# ── Resolve arena-web2api directory ────────────────────────────────────────
# Symlink resolve: tìm real path của script này
SCRIPT_PATH="$(readlink -f "${BASH_SOURCE[0]}" 2>/dev/null || echo "${BASH_SOURCE[0]}")"
ARENA_DIR="$(dirname "$SCRIPT_PATH")"

# Fallback: nếu script gọi qua symlink trong /usr/local/bin hoặc ~/.local/bin
if [ ! -f "$ARENA_DIR/main.py" ]; then
    # Thử common locations
    for candidate in "$HOME/arena-web2api-v4" "$HOME/arena-web2api" "/opt/arena-web2api-v4"; do
        if [ -f "$candidate/main.py" ]; then
            ARENA_DIR="$candidate"
            break
        fi
    done
fi

# Colors
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m' # No Color

log()   { echo -e "${GREEN}[arena]${NC} $*"; }
warn()  { echo -e "${YELLOW}[arena]${NC} $*"; }
err()   { echo -e "${RED}[arena]${NC} $*" >&2; }
info()  { echo -e "${BLUE}[arena]${NC} $*"; }

# ── Help ───────────────────────────────────────────────────────────────────
show_help() {
    cat << 'EOF'
arena — CLI cho arena-web2api

Commands:
  setup      Cài deps + tạo .env (interactive, không cần nano .env)
  start      Khởi động server + keepalive (background)
  stop       Dừng server + keepalive
  status     Xem trạng thái server, extension, cookie pool
  restart    Restart server (giữ keepalive)
  logs       Xem log real-time (Ctrl-C để thoát)
  test       Chạy test suite
  update     Git pull + restart server
  health     Deep health check (gọi /admin/health-deep)
  token      Test token gen qua extension
  cookie     Refresh cookie từ extension
  relogin    Yêu cầu extension relogin Arena
  uninstall  Remove symlink (giữ code)

Examples:
  arena setup
  arena start
  arena status
  arena logs
EOF
}

# ── Pre-flight: verify ARENA_DIR ───────────────────────────────────────────
check_dir() {
    if [ ! -f "$ARENA_DIR/main.py" ]; then
        err "Không tìm thấy arena-web2api directory"
        err "  Checked: $ARENA_DIR"
        err "  Set ARENA_DIR env var hoặc reinstall: cd $ARENA_DIR && bash install.sh"
        exit 1
    fi
}

# ── setup ──────────────────────────────────────────────────────────────────
cmd_setup() {
    check_dir
    log "Setup arena-web2api tại: $ARENA_DIR"
    echo ""

    # 1. Run setup.sh (cài deps)
    info "Bước 1/3: Cài dependencies..."
    cd "$ARENA_DIR"
    if [ -f setup.sh ]; then
        bash setup.sh || { err "setup.sh fail"; exit 1; }
    fi
    echo ""

    # 2. Create .env interactively
    info "Bước 2/3: Cấu hình .env (không cần nano)"
    if [ -f .env ] && [ "${1:-}" != "--force" ]; then
        warn ".env đã tồn tại. Backup .env.backup.$(date +%s) rồi tạo mới? (y/n)"
        read -r ans
        if [ "$ans" = "y" ] || [ "$ans" = "Y" ]; then
            cp .env ".env.backup.$(date +%s)"
        else
            log "Giữ .env hiện tại. Skip."
            return 0
        fi
    fi

    # Generate .env from .env.example với user input
    cat > .env << 'EOF'
# arena-web2api — auto-generated by `arena setup`
# Đừng edit thủ công — chạy `arena setup` lại nếu cần đổi

# Cookie (BẮT BUỘC)
EOF

    echo ""
    info "Cần cookie Arena. Lấy bằng 1 trong 2 cách:"
    echo "  Cách 1: Mở Kiwi Browser → cài extension → popup 'Test Cookies' → copy"
    echo "  Cách 2: Kiwi → arena.ai → DevTools → Application → Cookies"
    echo ""
    echo "Format cookie chunked (RECOMMENDED):"
    echo '  {"0":"base64-...","1":"mFzZV9..."}'
    echo ""
    echo -n "Paste ARENA_AUTH_COOKIE ( hoặc Enter để skip): "
    read -r auth_cookie
    echo "ARENA_AUTH_COOKIE=$auth_cookie" >> .env

    echo -n "Paste CF_CLEARANCE (hoặc Enter để skip): "
    read -r cf_clearance
    echo "CF_CLEARANCE=$cf_clearance" >> .env

    cat >> .env << 'EOF'

# reCAPTCHA solver (extension = free, recommended)
RECAPTCHA_SOLVER=extension
RECAPTCHA_SITE_KEY=6LeTGMcsAAAAALuIlkVwIxaAuZA8VledA6d3Nnb0
RECAPTCHA_ACTION=chat_submit
RECAPTCHA_TOKEN_TTL=90
RECAPTCHA_SOLVE_TIMEOUT=30
RECAPTCHA_MIN_SCORE=0.7

# Token broker (bind 0.0.0.0 để Kiwi extension reach được)
TOKEN_BROKER_HOST=0.0.0.0
TOKEN_BROKER_PORT=8765
TOKEN_BROKER_ENABLED=true

# Server (localhost only — secure)
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
DEBUG=false

# Cookie pool
COOKIE_HEALTH_TTL=300
COOKIE_FAIL_THRESHOLD=3
COOKIE_AUTO_REFRESH=true

# Retry
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY=1.5
RETRY_MAX_DELAY=30
RETRY_JITTER=0.3
REQUEST_TIMEOUT=120
CONNECT_TIMEOUT=15

# Conversation store (persist + long TTL cho agent dài)
CONVERSATION_TTL=7200
CONVERSATION_MAX_TURNS=50
CONVERSATION_STORE_FILE=./data/conversations.json

# Circuit breaker
CB_ENABLED=true
CB_FAILURE_THRESHOLD=5
CB_COOLDOWN=30
CB_HALF_OPEN_MAX=1

# Metrics
METRICS_ENABLED=true
EOF

    echo ""
    echo -n "Discord/Telegram webhook URL cho alert (Enter để skip): "
    read -r webhook
    if [ -n "$webhook" ]; then
        echo "export ALERT_WEBHOOK_URL=\"$webhook\"" >> ~/.bashrc
        log "Webhook saved to ~/.bashrc"
    fi

    echo ""
    info "Bước 3/3: Verify..."
    python3 precheck.py || { err "precheck fail — check .env"; exit 1; }

    echo ""
    log "✓ Setup hoàn tất!"
    echo ""
    echo "Bước tiếp theo:"
    echo "  1. Cài extension trên Kiwi Browser (xem extension/README.md)"
    echo "  2. Mở tab https://arena.ai trên Kiwi, login"
    echo "  3. Click icon extension → 'Save Credentials' (cho auto-relogin)"
    echo "  4. Chạy: arena start"
    echo ""
    echo "Test: arena status"
}

# ── start ──────────────────────────────────────────────────────────────────
cmd_start() {
    check_dir
    cd "$ARENA_DIR"

    # Check if already running
    if pgrep -f "keepalive.sh" >/dev/null 2>&1; then
        warn "keepalive.sh đã chạy. Dùng 'arena restart' để restart."
        return 0
    fi

    log "Khởi động arena-web2api..."
    log "  Dir: $ARENA_DIR"

    # Pre-flight check
    if [ ! -f .env ]; then
        err ".env không tồn tại. Chạy: arena setup"
        exit 1
    fi

    # Acquire wakelock (Termux)
    if command -v termux-wake-lock >/dev/null 2>&1; then
        termux-wake-lock 2>/dev/null || true
        log "  Wakelock: acquired"
    fi

    # Start keepalive DETACHED hoàn toàn khỏi terminal dùng setsid
    # setsid = tạo session mới, process không phụ thuộc terminal cha
    # Khi user close terminal, keepalive vẫn chạy
    if command -v setsid >/dev/null 2>&1; then
        setsid bash keepalive.sh > /tmp/keepalive.log 2>&1 < /dev/null &
    else
        # Fallback: nohup
        nohup bash keepalive.sh > /tmp/keepalive.log 2>&1 < /dev/null &
    fi
    disown 2>/dev/null || true
    log "  keepalive.sh started (detached)"
    log "  Log: /tmp/keepalive.log"

    # Wait for SERVER only (không đợi extension)
    info "Đợi server ready..."
    for i in {1..30}; do
        if curl -s -m 2 http://127.0.0.1:8000/health 2>/dev/null | grep -q '"ok"'; then
            log "✓ Server ready tại http://127.0.0.1:8000"
            echo ""
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo "Server chạy DETACHED — có thể close terminal."
            echo ""
            echo "Để chat hoạt động, cần:"
            echo "  1. Mở Kiwi Browser (nếu chưa mở)"
            echo "  2. Extension tự kết nối (check popup: '✓ Connected')"
            echo "  3. Tab arena.ai phải open + đã login"
            echo ""
            echo "Test: arena status (xem extension connected chưa)"
            echo "Stop: arena stop"
            echo "Logs: arena logs"
            echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
            echo ""
            cmd_status
            return 0
        fi
        sleep 1
        echo -n "."
    done
    echo ""
    err "Server không ready sau 30s. Check log:"
    err "  arena logs"
    err "  tail -50 /tmp/keepalive.log"
    exit 1
}

# ── stop ───────────────────────────────────────────────────────────────────
cmd_stop() {
    check_dir
    log "Dừng arena-web2api..."

    # Stop keepalive first (nó sẽ không restart server nữa)
    if pgrep -f "keepalive.sh" >/dev/null 2>&1; then
        pkill -f "keepalive.sh"
        log "  keepalive.sh stopped"
    fi

    # Stop server
    if pgrep -f "python3 main.py" >/dev/null 2>&1; then
        pkill -f "python3 main.py"
        log "  server stopped"
    fi

    # Release wakelock
    if command -v termux-wake-unlock >/dev/null 2>&1; then
        termux-wake-unlock 2>/dev/null || true
        log "  wakelock released"
    fi

    log "✓ Stopped"
}

# ── status ─────────────────────────────────────────────────────────────────
cmd_status() {
    check_dir

    echo ""
    info "arena-web2api status"
    echo ""

    # Server
    if curl -s -m 3 http://127.0.0.1:8000/health 2>/dev/null | grep -q '"ok"'; then
        echo -e "  Server:        ${GREEN}✓ running${NC} (http://127.0.0.1:8000)"
    else
        echo -e "  Server:        ${RED}✗ down${NC}"
    fi

    # Keepalive
    if pgrep -f "keepalive.sh" >/dev/null 2>&1; then
        echo -e "  keepalive.sh:  ${GREEN}✓ running${NC}"
    else
        echo -e "  keepalive.sh:  ${RED}✗ not running${NC}"
    fi

    # Kiwi
    if pgrep -f "kiwibrowser\|com.kiwibrowser" >/dev/null 2>&1; then
        echo -e "  Kiwi Browser:  ${GREEN}✓ running${NC}"
    else
        echo -e "  Kiwi Browser:  ${RED}✗ not running${NC} (cần cho extension)"
    fi

    # Extension + cookie pool (gọi API nếu server up)
    if curl -s -m 3 http://127.0.0.1:8000/health 2>/dev/null | grep -q '"ok"'; then
        echo ""
        broker_status=$(curl -s -m 3 http://127.0.0.1:8000/admin/broker 2>/dev/null)
        if [ -n "$broker_status" ]; then
            ext_connected=$(echo "$broker_status" | python3 -c "import json,sys; print(json.load(sys.stdin).get('extension_connected', False))" 2>/dev/null)
            token_count=$(echo "$broker_status" | python3 -c "import json,sys; print(json.load(sys.stdin).get('token_count', 0))" 2>/dev/null)
            if [ "$ext_connected" = "True" ]; then
                echo -e "  Extension:     ${GREEN}✓ connected${NC} (tokens gen: $token_count)"
            else
                echo -e "  Extension:     ${RED}✗ disconnected${NC} (mở Kiwi + extension)"
            fi
        fi

        cookie_status=$(curl -s -m 3 http://127.0.0.1:8000/admin/cookies 2>/dev/null)
        if [ -n "$cookie_status" ]; then
            healthy=$(echo "$cookie_status" | python3 -c "import json,sys; print(json.load(sys.stdin).get('healthy', 0))" 2>/dev/null)
            total=$(echo "$cookie_status" | python3 -c "import json,sys; print(json.load(sys.stdin).get('size', 0))" 2>/dev/null)
            echo -e "  Cookie pool:   ${GREEN}$healthy${NC}/$total healthy"
        fi
    fi

    echo ""
}

# ── restart ────────────────────────────────────────────────────────────────
cmd_restart() {
    check_dir
    log "Restart server..."
    pkill -f "python3 main.py" 2>/dev/null
    sleep 2
    cd "$ARENA_DIR"
    nohup python3 main.py >> /tmp/arena-server.log 2>&1 &
    disown
    sleep 3
    if curl -s -m 3 http://127.0.0.1:8000/health 2>/dev/null | grep -q '"ok"'; then
        log "✓ Restarted"
    else
        err "Restart fail — check log"
    fi
}

# ── logs ───────────────────────────────────────────────────────────────────
cmd_logs() {
    check_dir
    log "Log real-time (Ctrl-C để thoát)"
    echo ""
    # Tail cả 2 log files
    tail -F /tmp/keepalive.log /tmp/arena-server.log 2>/dev/null
}

# ── test ───────────────────────────────────────────────────────────────────
cmd_test() {
    check_dir
    cd "$ARENA_DIR"
    log "Chạy test suite..."
    bash tests/run_tests.sh
}

# ── update ─────────────────────────────────────────────────────────────────
cmd_update() {
    check_dir
    cd "$ARENA_DIR"
    log "Git pull..."
    git pull || { err "git pull fail"; exit 1; }
    log "Install deps..."
    pip3 install -r requirements.txt --quiet 2>/dev/null || pip3 install -r requirements.txt --quiet --break-system-packages 2>/dev/null
    log "Restart server..."
    cmd_restart
}

# ── health ─────────────────────────────────────────────────────────────────
cmd_health() {
    check_dir
    log "Deep health check..."
    curl -s http://127.0.0.1:8000/admin/health-deep 2>/dev/null | python3 -m json.tool 2>/dev/null || {
        err "Server không chạy hoặc /admin/health-deep fail"
        exit 1
    }
}

# ── token ──────────────────────────────────────────────────────────────────
cmd_token() {
    check_dir
    log "Test token gen qua extension..."
    curl -s -X POST http://127.0.0.1:8000/admin/broker/test 2>/dev/null | python3 -m json.tool 2>/dev/null || {
        err "Server không chạy hoặc broker test fail"
        exit 1
    }
}

# ── cookie ─────────────────────────────────────────────────────────────────
cmd_cookie() {
    check_dir
    log "Refresh cookie từ extension..."
    # Trigger qua admin endpoint — gọi /admin/cookies/validate rồi check
    curl -s -X POST http://127.0.0.1:8000/admin/cookies/validate 2>/dev/null | python3 -m json.tool 2>/dev/null
    echo ""
    log "Cookie pool sau refresh:"
    curl -s http://127.0.0.1:8000/admin/cookies 2>/dev/null | python3 -m json.tool 2>/dev/null
}

# ── relogin ────────────────────────────────────────────────────────────────
cmd_relogin() {
    check_dir
    log "Yêu cầu extension relogin Arena..."
    # Custom endpoint — gọi trực tiếp broker
    python3 -c "
import sys; sys.path.insert(0, '$ARENA_DIR')
import asyncio
from src.token_broker import broker

async def main():
    await broker.start(host='127.0.0.1', port=8765)
    await asyncio.sleep(0.5)
    try:
        ok = await broker.request_relogin(timeout=20)
        print(f'Relogin result: {\"✓ OK\" if ok else \"✗ failed\"}')
    except Exception as e:
        print(f'Error: {e}')
    await broker.stop()

asyncio.run(main())
" 2>&1 || err "Relogin fail"
}

# ── uninstall ──────────────────────────────────────────────────────────────
cmd_uninstall() {
    log "Remove 'arena' symlink..."
    for bin_dir in /usr/local/bin "$HOME/.local/bin" "$PREFIX/bin" "$HOME/bin"; do
        if [ -L "$bin_dir/arena" ]; then
            rm "$bin_dir/arena"
            log "  Removed: $bin_dir/arena"
        fi
    done
    log "✓ Uninstalled (code tại $ARENA_DIR vẫn còn)"
    log "  Để cài lại: cd $ARENA_DIR && bash install.sh"
}

# ── Main ───────────────────────────────────────────────────────────────────
case "${1:-}" in
    setup)    shift; cmd_setup "$@" ;;
    start)    cmd_start ;;
    stop)     cmd_stop ;;
    status)   cmd_status ;;
    restart)  cmd_restart ;;
    logs)     cmd_logs ;;
    test)     cmd_test ;;
    update)   cmd_update ;;
    health)   cmd_health ;;
    token)    cmd_token ;;
    cookie)   cmd_cookie ;;
    relogin)  cmd_relogin ;;
    uninstall) cmd_uninstall ;;
    -h|--help|help|"") show_help ;;
    *)
        err "Unknown command: $1"
        echo ""
        show_help
        exit 1
        ;;
esac
