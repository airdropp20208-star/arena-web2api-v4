{
  "manifest_version": 2,
  "name": "Arena Token Broker",
  "version": "2.0.0",
  "description": "HTTP polling token broker — không WebSocket, ổn định trên Android.",
  "permissions": [
    "tabs",
    "scripting",
    "storage",
    "alarms",
    "cookies",
    "https://arena.ai/*",
    "http://127.0.0.1/*",
    "http://localhost/*"
  ],
  "background": {
    "scripts": ["background.js"],
    "persistent": true
  },
  "browser_action": {
    "default_popup": "popup.html",
    "default_title": "Arena Token Broker",
    "default_icon": {
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "icons": {
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_security_policy": "script-src 'self'; object-src 'self'; connect-src http://127.0.0.1:* http://localhost:* https://arena.ai"
}
