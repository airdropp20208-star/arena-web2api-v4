# ================================================================
# arena-web2api v4 — cấu hình
# cp .env.example .env  →  điền giá trị thật vào .env
# ================================================================
#
# ⚠️  Arena backend ENFORCE reCAPTCHA Enterprise từ 2026-Q2.
#     Mặc định RECAPTCHA_SOLVER=skip sẽ bị 403.
#     Để hoạt động: đặt RECAPTCHA_SOLVER=2captcha + TWO_CAPTCHA_API_KEY
#     (xem chi tiết ở phần reCAPTCHA bên dưới).
# ================================================================

# ── Cookie (bắt buộc — ít nhất 1) ──────────────────────────────────
# Cookie Arena từ browser. Arena lưu auth trong CHUNKED cookies:
#   arena-auth-prod-v1.0 + arena-auth-prod-v1.1
# Điền 1 trong 2 cách:
#
# Cách 1 (LEGACY, có thể fail): ARENA_AUTH_COOKIE là JWT string
# ARENA_AUTH_COOKIE=eyJhbGci...
# CF_CLEARANCE=abc123xyz...
#
# Cách 2 (RECOMMENDED): ARENA_AUTH_COOKIE là JSON chứa cả 2 chunks
# Lấy bằng cách: DevTools → Application → Cookies → arena.ai → copy
# cả arena-auth-prod-v1.0 và arena-auth-prod-v1.1, gói thành JSON:
# ARENA_AUTH_COOKIE={"0":"base64-...","1":"mFzZV9kb21haW4i..."}
# CF_CLEARANCE=abc123xyz...

ARENA_AUTH_COOKIE=
CF_CLEARANCE=

# ── Cookie pool (tuỳ chọn — nhiều account xoay vòng) ───────────────
# Định dạng: "<auth>|<cf_clearance>,<auth2>|<cf2>,..."
# Mỗi <auth> có thể là JWT string (legacy) hoặc JSON chunked (recommended).
# COOKIE_POOL=auth1|cf1,auth2|cf2
COOKIE_HEALTH_TTL=300
COOKIE_FAIL_THRESHOLD=3
COOKIE_AUTO_REFRESH=false

# ── reCAPTCHA solver (BẮT BUỘC để chat hoạt động) ──────────────────
# Arena dùng reCAPTCHA Enterprise v3, backend hard-enforce từ 2026-Q2.
# Chiến lược:
#   skip       — Không gửi token. Arena sẽ 403 → KHÔNG hoạt động.
#   extension  — ✅ RECOMMENDED cho ĐT/VPS free. Kiwi Browser (Android)
#                cài extension, gen token trong arena.ai tab, gửi về server
#                qua WebSocket. Free, real Chrome fingerprint, multi-session OK.
#                Xem hướng dẫn: extension/README.md
#   2captcha   — Gọi 2Captcha API solve token. $1-3/1000 solves, latency 10-30s.
#                Cần TWO_CAPTCHA_API_KEY.
#   browser    — Gen token qua Playwright. Yêu cầu máy có display thật
#                (headless sẽ bị Google flag score thấp). KHÔNG dùng cho VPS.
RECAPTCHA_SOLVER=extension
# Đăng ký 2Captcha: https://2captcha.com (chỉ cần nếu RECAPTCHA_SOLVER=2captcha)
TWO_CAPTCHA_API_KEY=
RECAPTCHA_SITE_KEY=6LeTGMcsAAAAALuIlkVwIxaAuZA8VledA6d3Nnb0
RECAPTCHA_ACTION=chat_submit
RECAPTCHA_TOKEN_TTL=90
RECAPTCHA_SOLVE_TIMEOUT=30
RECAPTCHA_MIN_SCORE=0.7

# ── Token broker (cho extension strategy) ──────────────────────────
# WebSocket server mà extension kết nối tới. Mặc định localhost:8765.
# Nếu server chạy trên Termux (ĐT), giữ mặc định — extension trên Kiwi Browser
# cùng ĐT sẽ connect qua ws://localhost:8765.
TOKEN_BROKER_HOST=127.0.0.1
TOKEN_BROKER_PORT=8765
TOKEN_BROKER_ENABLED=true

# ── Arena credentials (cho browser solver — tuỳ chọn) ──────────────
# Chỉ cần nếu RECAPTCHA_SOLVER=browser. Skip nếu dùng 2captcha.
# ARENA_EMAIL=you@example.com
# ARENA_PASSWORD=yourpassword

# ── Server ─────────────────────────────────────────────────────────
# Default bind 127.0.0.1 (localhost only) — secure.
# Set HOST=0.0.0.0 ONLY if need access from LAN, AND set API_KEYS + ADMIN_TOKEN.
HOST=127.0.0.1
PORT=8000
LOG_LEVEL=INFO
DEBUG=false
# Bảo vệ endpoint /admin/* (trống = cho phép tất cả — KHÔNG recommended)
# ADMIN_TOKEN=changeme
# CORS origins (CSV). Default: localhost only. Set * to allow all (NOT recommended).
# CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Retry & timeout ────────────────────────────────────────────────
RETRY_ATTEMPTS=3
RETRY_BASE_DELAY=1.5
RETRY_MAX_DELAY=30
RETRY_JITTER=0.3
REQUEST_TIMEOUT=120
CONNECT_TIMEOUT=15

# ── Proxy (tuỳ chọn) ───────────────────────────────────────────────
# PROXY=http://user:pass@host:port
# Pool proxy xoay vòng (CSV):
# PROXY_POOL=http://p1:port,http://p2:port

# ── Model registry (dynamic UUID sync) ─────────────────────────────
MODEL_REGISTRY_TTL=600
MODEL_REGISTRY_ON_STARTUP=true

# ── Conversation store (multi-turn thật) ───────────────────────────
# Quan trọng cho agent liên tục + dự án dài:
#   - Set CONVERSATION_STORE_FILE để persist state ra file (survive restart)
#   - Tăng CONVERSATION_TTL để conversation không expire quá nhanh
# Default TTL 1800s (30 phút) — quá ngắn cho agent dài.
# Khuyến nghị: 7200s (2h) cho solo use, 14400s (4h) cho agent autonomous.
CONVERSATION_TTL=7200
CONVERSATION_MAX_TURNS=50
CONVERSATION_STORE_FILE=./data/conversations.json

# ── Rate limiter ───────────────────────────────────────────────────
RATE_LIMIT_ENABLED=false
RATE_LIMIT_RPM=60
RATE_LIMIT_TPM=0

# ── Circuit breaker ────────────────────────────────────────────────
CB_ENABLED=true
CB_FAILURE_THRESHOLD=5
CB_COOLDOWN=30
CB_HALF_OPEN_MAX=1

# ── Tokenizer ──────────────────────────────────────────────────────
TOKENIZER_ENCODING=o200k_base
TOKENIZER_FALLBACK_HEURISTIC=true

# ── Metrics ────────────────────────────────────────────────────────
METRICS_ENABLED=true
